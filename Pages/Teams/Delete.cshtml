@page "{id:int}"
@model Projeto.Pages.Teams.DeleteModel

<h1>Eliminar equipa</h1>

@* Caso a equipa não exista, é apresentada uma mensagem simples ao utilizador. *@
@if (Model.Team == null)
{
    <p>Equipa não encontrada.</p>
}
else
{
    @* Aviso de confirmação para evitar eliminações acidentais. *@
    <div class="alert alert-warning">
        Tens a certeza que queres eliminar esta equipa?
    </div>

    @* Lista de detalhes da equipa que será eliminada, para o utilizador confirmar que é a correta. *@
    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Model.Team.Name</dd>

        <dt class="col-sm-2">País</dt>
        <dd class="col-sm-10">@Model.Team.Country</dd>
    </dl>

    @* Ao submeter este formulário, é chamado o método OnPostAsync do Delete.cshtml.cs. *@
    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Team.Id" />
        <button type="submit" class="btn btn-danger">Eliminar</button>
        @* Cancela a operação e volta à listagem. *@
        <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
    </form>
}
