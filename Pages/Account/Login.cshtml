@page
@model Projeto.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Iniciar sessão";
}

<h1>Iniciar sessão</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <h2>Utilize a sua conta para iniciar sessão</h2>

            <hr />

            <div asp-validation-summary="ModelOnly"
                 class="text-danger"
                 role="alert">
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email"
                       class="form-control"
                       autocomplete="username"
                       placeholder="nome@exemplo.com" />

                <label asp-for="Input.Email">
                    Endereço de email
                </label>

                <span asp-validation-for="Input.Email"
                      class="text-danger">
                </span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password"
                       class="form-control"
                       autocomplete="current-password"
                       placeholder="Palavra-passe" />

                <label asp-for="Input.Password">
                    Palavra-passe
                </label>

                <span asp-validation-for="Input.Password"
                      class="text-danger">
                </span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="Input.RememberMe"
                       class="form-check-input" />

                <label asp-for="Input.RememberMe"
                       class="form-check-label">
                    Manter sessão iniciada
                </label>
            </div>

            <button type="submit"
                    class="w-100 btn btn-lg btn-primary">
                Iniciar sessão
            </button>
        </form>

        <p class="mt-3">
            <a asp-page="/Account/Register">
                Criar uma nova conta
            </a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}