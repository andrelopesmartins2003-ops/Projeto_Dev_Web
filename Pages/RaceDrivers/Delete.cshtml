@page
@model Projeto.Pages.RaceDrivers.DeleteModel

@* Título *@
<h1>Eliminar participação</h1>

@* Verifica se o objeto RaceDriver é nulo e mostra uma mensagem de erro*@
@*Caso contrário, exibe os detalhes da participação e um formulário para confirmar a eliminação. *@

@if (Model.RaceDriver == null)
{
    <p>Participação não encontrada.</p>
}
else
{
    <div class="alert alert-warning">
        Tens a certeza que queres eliminar esta participação?
    </div>

    <dl class="row">
        <dt class="col-sm-2">Corrida</dt>
        <dd class="col-sm-10">@Model.RaceDriver.Race?.GrandPrixName</dd>

        <dt class="col-sm-2">Piloto</dt>
        <dd class="col-sm-10">@Model.RaceDriver.Driver?.Name</dd>

        <dt class="col-sm-2">Equipa</dt>
        <dd class="col-sm-10">@Model.RaceDriver.Driver?.Team?.Name</dd>

        <dt class="col-sm-2">Posição</dt>
        <dd class="col-sm-10">@Model.RaceDriver.Position</dd>
    </dl>

@* Formulário para confirmar a eliminação da participação. *@
<form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="RaceDriver.RaceId" />
        <input type="hidden" asp-for="RaceDriver.DriverId" />
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
    </form>
}