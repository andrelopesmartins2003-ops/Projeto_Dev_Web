@* Importa a biblioteca jQuery Validate, responsável por validar formulários no lado do cliente. *@
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>

@* Importa a integração unobtrusive, que liga as validações do ASP.NET Core aos atributos HTML gerados nos formulários. *@
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
