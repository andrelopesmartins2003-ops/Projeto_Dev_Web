@* Define esta página como uma Razor Page. *@
@page
@* Liga esta vista ao respetivo PageModel (.cs). *@
@model Projeto.Pages.RaceDrivers.CreateModel

<h1>Adicionar piloto a corrida</h1>

<!-- Formulário utilizado para enviar os dados para o servidor. -->
<form method="post">
    <div class="form-group mb-3">
<!-- Liga este campo à propriedade correspondente do modelo. -->
        <label asp-for="RaceDriver.RaceId">Corrida</label>
<!-- Liga este campo à propriedade correspondente do modelo. -->
        <select asp-for="RaceDriver.RaceId" class="form-control" asp-items="Model.RaceOptions">
            <option value="">-- selecionar corrida --</option>
        </select>
<!-- Mostra mensagens de validação para este campo. -->
        <span asp-validation-for="RaceDriver.RaceId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
<!-- Liga este campo à propriedade correspondente do modelo. -->
        <label asp-for="RaceDriver.DriverId">Piloto</label>
<!-- Liga este campo à propriedade correspondente do modelo. -->
        <select asp-for="RaceDriver.DriverId" class="form-control" asp-items="Model.DriverOptions">
            <option value="">-- selecionar piloto --</option>
        </select>
<!-- Mostra mensagens de validação para este campo. -->
        <span asp-validation-for="RaceDriver.DriverId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
<!-- Liga este campo à propriedade correspondente do modelo. -->
        <label asp-for="RaceDriver.Position">Posição</label>
<!-- Liga este campo à propriedade correspondente do modelo. -->
        <select asp-for="RaceDriver.Position" class="form-control">
        @for (int i = 1; i <= 22; i++)
        {
            <option value="@i">@i</option>
        }
        <option value="DNF">DNF</option>
        <option value="DNS">DNS</option>
        <option value="DSQ">DSQ</option>
        <option value="NC">NC</option>
         </select>
<!-- Mostra mensagens de validação para este campo. -->
        <span asp-validation-for="RaceDriver.Position" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
<!-- Link para outra Razor Page da aplicação. -->
    <a asp-page="Index" class="btn btn-secondary">Voltar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}